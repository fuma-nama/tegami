{
  "name": "root",
  "private": true,
  "scripts": {
    "prepare": "ts-patch install",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "oxlint",
    "lint:format": "oxfmt --check",
    "format": "oxfmt",
    "test": "vitest",
    "types:check": "turbo run types:check",
    "tegami": "pnpm --filter tegami build && node scripts/tegami.mts"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@typia/unplugin": "^12.1.1",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "tegami": "workspace:*",
    "tinyexec": "^1.2.4",
    "ts-patch": "^4.0.1",
    "turbo": "^2.10.3",
    "typescript": "6.0.3",
    "typia": "^12.1.1",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.6.0"
}
