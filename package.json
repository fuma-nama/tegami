    "tinyexec": "^1.2.4",
    "turbo": "^2.10.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.6.0"
