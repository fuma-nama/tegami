    "tinyexec": "^1.2.4",
    "tinyglobby": "^0.2.17",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^26.1.1",
    "@types/semver": "^7.7.1",
    "package-manager-detector": "^1.7.0",
    "tsdown": "^0.22.12",
    "typescript": "6.0.3",
    "typia": "^12.1.1"
  },
  "inlinedDependencies": {
    "@typia/interface": "12.1.1",
    "package-manager-detector": "1.7.0",
    "typia": "12.1.1"
  }
