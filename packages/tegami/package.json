{
  "name": "tegami",
  "version": "1.0.0-beta.4",
  "description": "Utility for package versioning & publish",
  "license": "MIT",
  "author": "Fuma Nama",
  "repository": "github:fuma-nama/tegami",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./cli": "./dist/cli/index.js",
    "./generators/simple": "./dist/generators/simple.js",
    "./plugins/git": "./dist/plugins/git.js",
    "./plugins/github": "./dist/plugins/github.js",
    "./plugins/gitlab": "./dist/plugins/gitlab.js",
    "./plugins/go": "./dist/plugins/go.js",
    "./plugins/pip": "./dist/plugins/pip.js",
    "./providers/cargo": "./dist/providers/cargo.js",
    "./providers/npm": "./dist/providers/npm.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "types:check": "tsc --noEmit",
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "@rainbowatcher/toml-edit-js": "^0.6.5",
    "js-yaml": "^5.1.0",
    "package-manager-detector": "^1.6.0",
    "semver": "^7.8.5",
    "tinyexec": "^1.2.4",
    "tinyglobby": "^0.2.17",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^26.0.0",
    "@types/semver": "^7.7.1",
    "tsdown": "^0.22.3",
    "typescript": "6.0.3"
  }
}
