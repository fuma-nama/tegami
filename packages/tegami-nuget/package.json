{
  "name": "@tegami/nuget",
  "version": "0.1.0",
  "description": ".NET project support and NuGet publishing for Tegami",
  "license": "MIT",
  "author": "Fuma Nama",
  "repository": "github:fuma-nama/tegami",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "types:check": "tsc --noEmit",
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "dependencies": {
    "@tegami/xml-util": "workspace:*",
    "semver": "^7.8.5",
    "tinyexec": "^1.2.4",
    "tinyglobby": "^0.2.17"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^26.1.1",
    "@types/semver": "^7.7.1",
    "tegami": "workspace:*",
    "tsdown": "^0.22.12",
    "typescript": "6.0.3",
    "typia": "^12.1.1"
  },
  "peerDependencies": {
    "tegami": "^1.2.0"
  },
  "inlinedDependencies": {
    "typia": "12.1.1"
  }
}
