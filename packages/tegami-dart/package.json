{
  "name": "@tegami/dart",
  "version": "1.0.0",
  "description": "Dart pub workspace support and pub.dev publishing for Tegami",
  "license": "MIT",
  "author": "Fuma Nama",
  "repository": "github:fuma-nama/tegami",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "types:check": "tsc --noEmit",
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "dependencies": {
    "js-yaml": "^5.2.0",
    "semver": "^7.8.5",
    "tinyexec": "^1.2.4",
    "tinyglobby": "^0.2.17",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^26.0.1",
    "@types/semver": "^7.7.1",
    "tegami": "workspace:*",
    "tsdown": "^0.22.3",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "tegami": "workspace:*"
  }
}
