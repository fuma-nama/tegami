{
  "name": "@tegami/pip",
  "version": "1.2.2",
  "description": "Python workspace support and PyPI publishing for Tegami",
  "license": "MIT",
  "author": "Fuma Nama",
  "repository": "github:fuma-nama/tegami",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "types:check": "tsc --noEmit",
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "dependencies": {
    "@rainbowatcher/toml-edit-js": "^0.6.5",
    "tinyexec": "^1.2.4",
    "tinyglobby": "^0.2.17"
  },
  "devDependencies": {
    "@renovatebot/pep440": "^5.0.0",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^26.1.0",
    "tegami": "workspace:*",
    "tsdown": "^0.22.3",
    "typescript": "6.0.3",
    "typia": "^12.1.1"
  },
  "peerDependencies": {
    "tegami": "workspace:*"
  },
  "inlinedDependencies": {
    "@renovatebot/pep440": "5.0.0",
    "typia": "12.1.1"
  }
}
